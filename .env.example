# ChainSocial Environment Variables
# Copy this file to .env.local and fill in your values

# Lens Protocol Configuration
# Your Lens App address (required for accountOwner authentication)
LENS_APP_ADDRESS=

# Lens API endpoint (defaults to https://api.lens.xyz/graphql)
LENS_API_URL=https://api.lens.xyz/graphql

# Data source for posts: "lens" to use Lens Protocol, "local" for local storage
LENS_POSTS_SOURCE=lens

# Application URL (used for CORS/Origin headers)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# IPFS Storage (optional - at least one recommended for media uploads)
# Get a Pinata JWT at https://app.pinata.cloud/
PINATA_JWT=

# Get a Web3.Storage token at https://web3.storage/
WEB3_STORAGE_TOKEN=

# Privy Authentication (for wallet connection)
# Get your keys at https://privy.io/
NEXT_PUBLIC_PRIVY_APP_ID=

# Node Environment
NODE_ENV=development

# Production architecture backends
# State backend: file (default) or postgres
CHAINSOCIAL_STATE_BACKEND=file
# DATABASE_URL=postgres://user:pass@host:5432/dbname
# Fail-fast Postgres settings
CHAINSOCIAL_STATE_FAILOVER_TO_FILE=true
CHAINSOCIAL_DB_CONNECT_TIMEOUT_MS=2500
CHAINSOCIAL_DB_QUERY_TIMEOUT_MS=3000
CHAINSOCIAL_DB_OPERATION_TIMEOUT_MS=3500
CHAINSOCIAL_DB_FAILOVER_COOLDOWN_MS=30000
# Best-effort local merge timeout when feed source is Lens
CHAINSOCIAL_LENS_LOCAL_MERGE_TIMEOUT_MS=700
# Local feed read timeout budget (source=local and Lens local fallback reads)
CHAINSOCIAL_LOCAL_READ_TIMEOUT_MS=1200
# Follow stats API timeout budget
CHAINSOCIAL_FOLLOWS_TIMEOUT_MS=1200

# Local file path used when CHAINSOCIAL_STATE_BACKEND=file
CHAINSOCIAL_STATE_FILE=data/posts.json

# Metadata fetch allow-list for Lens contentUri/metadataUri (comma separated hostnames)
# LENS_METADATA_ALLOWED_HOSTS=ipfs.io,gateway.pinata.cloud,arweave.net

# Media storage backend: local (default) or remote
CHAINSOCIAL_MEDIA_BACKEND=local
# CHAINSOCIAL_MEDIA_REMOTE_URL=https://your-media-service/upload
# CHAINSOCIAL_MEDIA_REMOTE_TOKEN=

# Distributed rate limit (Upstash Redis REST). If omitted, local in-memory fallback is used.
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=

# ============================================
# Region-aware compliance controls / kill switches
# ============================================

# Emergency platform read-only mode for all API writes
CHAINSOCIAL_GLOBAL_READ_ONLY=false

# Full service block in specific countries (ISO-3166 alpha-2, comma-separated)
# Example: IN,CN
CHAINSOCIAL_BLOCKED_COUNTRIES=

# Only write operations blocked in specific countries
# Example: BR,ID
CHAINSOCIAL_WRITE_BLOCKED_COUNTRIES=

# Global feature kill switches
CHAINSOCIAL_DISABLE_LENS=false
CHAINSOCIAL_DISABLE_POSTS=false
CHAINSOCIAL_DISABLE_FOLLOWS=false
CHAINSOCIAL_DISABLE_MEDIA_UPLOADS=false
CHAINSOCIAL_DISABLE_MESSAGES=false
CHAINSOCIAL_DISABLE_NOTIFICATIONS=false

# Feature kill switches by country (ISO-3166 alpha-2, comma-separated)
CHAINSOCIAL_DISABLE_LENS_COUNTRIES=
CHAINSOCIAL_DISABLE_POSTS_COUNTRIES=
CHAINSOCIAL_DISABLE_FOLLOWS_COUNTRIES=
CHAINSOCIAL_DISABLE_MEDIA_UPLOADS_COUNTRIES=
CHAINSOCIAL_DISABLE_MESSAGES_COUNTRIES=
CHAINSOCIAL_DISABLE_NOTIFICATIONS_COUNTRIES=

# Compliance operations
# Admin token used for compliance admin endpoints:
# - GET/PATCH /api/admin/compliance/dsar
# - POST /api/admin/compliance/retention
CHAINSOCIAL_ADMIN_TOKEN=

# Retention window (days)
CHAINSOCIAL_RETENTION_DAYS_AUDIT=90
CHAINSOCIAL_RETENTION_DAYS_DSAR_COMPLETED=365
